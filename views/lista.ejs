<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Produtos</title>
</head>
 <style>
        body{font-family: Arial, Helvetica, sans-serif; padding: 20px;}
        table{ border-collapse: collapse; width: 100%;}
        th,td{border: 1px solid #ddd; padding: 8px;}
        th{background-color: #222; color: white}
        form {margin-bottom: 20px;}
        input{ margin-right: 10px; padding: 5px; }
        button {padding: 5px;}
    </style>
<body>
    <h1> Produtos Cadastrados </h1>
    <form id="formProduto"> 
       
<input type="text" id="nome" placeholder="Nome do produto" required />
        <input type="number" id="preco" step="0.01" placeholder="Preço (R$)" required/>
        <button type="submit">Cadastrar</button>

    </form>
    <table>
        <thead>
            <tr>
                 <th>ID</th>
                 <th>Nome</th>
                 <th>Preço</th>
                 <th>Ações</th>
            </tr>
        </thead>
        <tbody> 
            <% produtos.forEach(produto =>  {%>
            <tr>
                <td><%= produto.id %></td>
                <td><%= produto.nome %></td>
                <td><%= produto.preco.toFixed(2) %></td>
                <td>
                    <button onclick="deletar(<%= produto.id %>)">Deletar</button>
                    <button onclick="atualizar(<%= produto.id %>, '<%= produto.nome %>', <%= produto.preco %>)">Editar</button>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    <script>
        const form = document.getElementById('formProduto')
        form.addEventListener('submit', async(e) => {
            e.preventDefault();
            const nome = document.getElementById('nome').value;
            const preco = parseFloat(document.getElementById('preco').value);

            const res = await fetch('/produtos', {
                method: 'POST', 
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({nome,preco})
            });

            if (res.ok){
                alert('Produto cadastrado com sucesso')
                window.location.reload();
            }else{
                alert('Erro ao cadastrar o produto.')
            }
        });

        async function deletar(id) {
            if (!confirm('Tem certeza que deseja deletar este produto?')) return;

            const res = await fetch('/produtos/'+id, { 
                method: 'DELETE',
                headers:{'Content-Type':'application/json'}
            });

            if (res.ok) {
                alert('Produto excluido com sucesso!')
                window.location.reload();
            } else {
                alert('Erro ao deletar o produto.');
            }
        }

        async function atualizar(id, nomeAtual, precoAtual) {
            const novoNome = prompt('Novo nome:', nomeAtual);
            if (novoNome === null) return; 
            if (novoNome.trim() === '') {       
                alert('O nome não pode ser vazio!');
                return;
            }

            const novoPreco = parseFloat(prompt('Novo preço:', precoAtual));
            if (novoPreco === null) return;        
            if (isNaN(novoPreco)) {              
                alert('O preço não pode ser vazio!');
                return;
            }

            const res = await fetch('/produtos/'+id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nome: novoNome, preco: novoPreco })
            });

            if (res.ok) {
                alert('Produto atualizado com sucesso!');
                window.location.reload();
            } else {
                alert('Erro ao atualizar o produto.');
            }
        }
    </script>
</body>
</html>
